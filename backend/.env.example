# Скопируй этот файл в .env и заполни значения
# cp .env.example .env   (Mac/Linux)
# copy .env.example .env  (Windows)

# Секретный ключ Django — обязательно сгенерируй свой!
# Команда: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-change-this

# True во время разработки, False на продакшне
DEBUG=True

# Настройки базы данных PostgreSQL
# Должны совпадать с docker-compose.yml
DB_NAME=pygen_db
DB_USER=pygen_user
DB_PASSWORD=pygen_password
DB_HOST=127.0.0.1
DB_PORT=5433

# Разрешённые источники для CORS (откуда фронт будет делать запросы)
CORS_ALLOWED_ORIGINS=http://localhost:3000
